# Enforce LF line endings for all text files in the repo
# This prevents Black/isort CI failures caused by CRLF on Linux runners
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.env   text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Keep these binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
